PORT=4000
DB_PATH=./data/crabsem.sqlite
NODE_ENV=development

# Comma-separated browser origins allowed to call this API, e.g.
# https://crabsem.com,https://www.crabsem.com
# Leave empty in local development (falls back to permissive CORS).
# Required for a production deployment - see server/INTELLIGENCE_ENGINE.md
# and the production-readiness audit.
CORS_ALLOWED_ORIGINS=

# GMGN OpenAPI (https://openapi.gmgn.ai)
# Populated automatically by `npm run gmgn:generate-keys`, except
# GMGN_API_KEY which you obtain manually by registering the generated
# public key at https://gmgn.ai/ai.
GMGN_HOST=https://openapi.gmgn.ai
GMGN_API_KEY=
GMGN_PRIVATE_KEY=
